# Groq free-tier API key. Leave blank to run with deterministic summaries (no LLM).
# Get one at https://console.groq.com/keys
GROQ_API_KEY=

# Optional local JSONL usage log for completed analyses.
# Set to off/false/0/none to disable file logging; events still appear in logs.
KINTSUGI_USAGE_LOG_PATH=.usage/kintsugi_usage_events.jsonl
